PORT=3001
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME?sslmode=require
CORS_ORIGIN=*
REQUEST_BODY_LIMIT=15mb
IMAGE_MAX_BYTES=350000
IMAGE_COMPRESSION_ATTEMPTS=8
IMAGE_MAX_DIMENSION=900
IMAGE_MIN_DIMENSION=280
IMAGE_QUALITY=60
IMAGE_PROVIDER=cloudinary
# Option A (signed, recomendado): preencha CLOUDINARY_URL
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_URL=cloudinary://api_key:api_secret@your_cloud_name

# Option B (unsigned preset): deixe CLOUDINARY_URL vazio e use preset
CLOUDINARY_UPLOAD_PRESET=your_unsigned_upload_preset
CLOUDINARY_UPLOAD_FOLDER=ficha-rpg
